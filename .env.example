APP_NAME=LexCita
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

# ─── Base de datos MySQL ─────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lexcita
DB_USERNAME=root
DB_PASSWORD=

# ─── Sesiones ────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ─── Stripe (Pagos) ──────────────────────────────────────────
# Obtén tus claves en: https://dashboard.stripe.com/test/apikeys
STRIPE_KEY=pk_test_XXXXXXXXXX
STRIPE_SECRET=sk_test_XXXXXXXXXX

# ─── Twilio (WhatsApp) ───────────────────────────────────────
# Regístrate en: https://www.twilio.com/try-twilio
# Sandbox: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
